# Enforce consistent line endings across all platforms
* text=auto eol=lf

# Explicitly LF for source files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.mjs   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary files — no line ending conversion
*.ico   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary